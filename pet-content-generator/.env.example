# ─── Generator ────────────────────────────────────────────────────────────────
# Image Generator: "mock" (default) | "gemini" | "openai" | "stability"
IMAGE_GENERATOR=mock

# Output directory (inside container)
OUTPUT_DIR=/app/app/outputs

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Set only the keys you actually use. Unused keys can be left blank or removed.

# Google Gemini (動画生成などに使用)
GEMINI_API_KEY=

# OpenAI / DALL-E (画像生成に使用)
OPENAI_API_KEY=

# Stability AI (画像生成に使用)
STABILITY_API_KEY=
